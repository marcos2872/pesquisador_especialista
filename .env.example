HOST=127.0.0.1
PORT=8000

# OpenAI / Azure OpenAI (obrigatorio)
# Para OpenAI: https://api.openai.com/v1
# Para Azure: https://SEU-RECURSO.openai.azure.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Chaves opcionais para busca de fontes (veja docs/setup.md)
# CORE_API_KEY=
# SEMANTIC_SCHOLAR_API_KEY=
# IEEE_API_KEY=
# SERPAPI_API_KEY=
# EPO_OPS_CONSUMER_KEY=
# EPO_OPS_CONSUMER_SECRET=
# USPTO_API_KEY=
# LENS_API_TOKEN=
# WIPO_API_KEY=

# Configuracao da busca
SEARCH_TIMEOUT_SECONDS=30
ENABLE_REAL_SEARCH=1
