HOST=127.0.0.1
PORT=8000

# OpenAI/Azure OpenAI
# Para OpenAI: https://api.openai.com/v1
# Para Azure: https://SEU-RECURSO.openai.azure.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_DEBUG=0
OPENAI_TIMEOUT_SECONDS=240

# Busca de fontes (todas opcionais; sem elas o sistema ja funciona
# com Crossref + OpenAlex + arXiv + Core.ac.uk, que sao gratuitas e sem cadastro)
OPENALEX_USER_AGENT=
UNPAYWALL_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
IEEE_API_KEY=
USPTO_API_KEY=
EPO_OPS_CONSUMER_KEY=
EPO_OPS_CONSUMER_SECRET=
LENS_API_TOKEN=
WIPO_API_KEY=
# SerpAPI — Google Scholar, Google Patents (https://serpapi.com)
SERPAPI_API_KEY=

# Configuracao da busca
SEARCH_TIMEOUT_SECONDS=30
ENABLE_REAL_SEARCH=1
